# This file stores theme settings that sync across browsers

config theme 'settings'
option mode 'auto'
option accent 'blue'
option accent_custom '#5e9eff'
option zoom '100'
option transparency '1'
option border_radius 'default'
option tab_outline '0'
option animations '1'
option services_widget '1'
option temp_widget '1'
option services_log '0'
option table_wrap '1'
option log_highlight '1'
option page_width '0'
option custom_font '1'
option login_animation 'particles'
option login_branding '0'
option login_name ''
option login_logo ''
option login_logo_only '0'
